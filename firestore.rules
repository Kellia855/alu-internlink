rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ----------------------------
    // User profiles
    // ----------------------------
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ----------------------------
    // Opportunities
    // ----------------------------
    match /opportunities/{opportunityId} {
      // Authenticated users can read opportunities.
      // Students can only read verified opportunities.
      allow read: if request.auth != null && (
        // If user is a startup account, allow reading any opportunity.
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'startup'
        )
        // Otherwise (student), only allow verified opportunities.
        || resource.data.verified == true
      );


      // Startups can create opportunities.
      allow create: if request.auth != null && (
        exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'startup'
      );

      // Startups can update their own opportunities; students cannot modify.
      allow update, delete: if request.auth != null && (
        exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'startup'
        && resource.data.startupId == request.auth.uid
      );
    }

    // ----------------------------
    // Applications
    // ----------------------------
    match /applications/{applicationId} {
      // Authenticated users can create an application
      allow create: if request.auth != null;

      // Students can read their own applications
      allow read: if request.auth != null && resource.data.studentId == request.auth.uid;

      // Startups can read applications they've received
      // (use the denormalized startupId already stored on the application doc)
      allow read: if request.auth != null && resource.data.startupId == request.auth.uid;

      // Only the student who created the application can update it.
      // Startups can update status for applications they've received.
      allow update, delete: if request.auth != null && (
        resource.data.studentId == request.auth.uid
        || resource.data.startupId == request.auth.uid
      );
    }

    // ----------------------------
    // Notifications
    // ----------------------------
    match /notifications/{notificationId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
    }
  }
}

